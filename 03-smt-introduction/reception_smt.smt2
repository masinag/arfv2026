(set-option :produce-models true)
(declare-const A Int)
(declare-const B Int)
(declare-const C Int)
(declare-const D Int)
(declare-const E Int)
(define-fun is-assigned-a-room ((x Real)) Bool (and (>= x 1) (<= x 5)))
(assert (is-assigned-a-room A))
(assert (is-assigned-a-room B))
(assert (is-assigned-a-room C))
(assert (is-assigned-a-room D))
(assert (is-assigned-a-room E))
(assert (distinct A B C D E))

(assert (or (= A 1) (= A 2)))
(assert (or (= B 2) (= B 4)))
(assert (= C 1))
(assert (or (= D 2) (= D 4)))
(assert (or (= E 1) (= E 5)))

(check-sat)
